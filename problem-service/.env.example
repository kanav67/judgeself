NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
PGPOOL_MAX=10
POLYGON_BASE_URL=https://codeforces.com
ISOLATE_BINARY=isolate
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=problem-service
S3_SECRET_ACCESS_KEY=problem-service-secret
S3_BUCKET=problem-service-artifacts
S3_FORCE_PATH_STYLE=true
POLYGON_USERNAME=your_polygon_username
POLYGON_PASSWORD=your_polygon_password
POLYGON_TMPDIR=/tmp/polygon
POLYGON_ALLOW_GENERATE_TESTS=false